{
    "manifest_version": 3,
    "name": "Unagent",
    "version": "1.10",
    "default_locale": "en",
    "icons": {
        "128": "128.png"
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "content_scripts": [
        {
            "js": [
                "content.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "description": "__MSG_extensionDescription__",
    "permissions": [
        "declarativeNetRequestWithHostAccess",
        "nativeMessaging",
        "storage"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https:;"
    },
    "declarative_net_request": {
        "rule_resources": []
    }
}
