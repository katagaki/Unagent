    "More.AutoRefresh": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update User Agent Rules Immediately"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーエージェントルールを即時更新"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "立即更新用户代理规则"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "立即更新使用者代理規則"
          }
        }
      }
    },
    "More.AutoRefresh.Description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When turned on, any user agent change will cause a refresh the next time you visit a webpage in Safari. When turned off, user agents will only be updated on the 2nd webpage you visit or load."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、ユーザーエージェントを変更した際にSafariで次に訪問するWebページが自動的にリロードされます。オフの場合、変更後2つ目に訪問するWebページから反映されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，任何用户代理更改都会在您下次访问Safari中的网页时自动刷新。关闭后，用户代理仅在您访问或加载的第2个网页时更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，任何使用者代理變更都會在您下次造訪Safari中的網頁時自動重新整理。關閉後，使用者代理僅在您造訪或載入的第2個網頁時更新。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
