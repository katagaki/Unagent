    "SiteSettings.DomainName.Example": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the domain name without any ‘http’ at the front, or slashes at the back.\nExample: www.example.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「http」やスラッシュー記号なしのドメイン名を入力してください。\n例：www.example.co.jp"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite o nome do domínio sem ‘http’ no início e sem barras no final.\nExemplo: www.example.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：www.example.com"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：www.example.com"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie den Domainnamen ohne ‘http’ am Anfang oder Schrägstriche am Ende ein.\nBeispiel: www.example.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduzca el nombre de dominio sin ‘http’ al principio ni barras al final.\nEjemplo: www.example.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez le nom de domaine sans « http » au début ni barre oblique à la fin.\nExemple : www.example.com"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci il nome di dominio senza ‘http’ all’inizio o barre alla fine.\nEsempio: www.example.com"
          }
        }
      }
    },
    "SiteSettings.DomainName.Footer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This user agent will only apply to pages in the domain specified."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このユーザーエージェントは指定したドメインのページのみ適用されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse agente de usuário será apenas aplicado à páginas deste domínio específico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此用户代理将仅应用于指定域中的页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此使用者代理將僅套用於指定網域中的頁面。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser User-Agent wird nur auf Seiten der angegebenen Domain angewendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este agente de usuario solo se aplicará a las páginas del dominio especificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet agent utilisateur ne s’appliquera qu’aux pages du domaine spécifié."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo user agent si applicherà solo alle pagine del dominio specificato."
          }
        }
      }
    },
    "SiteSettings.EmptyText.Text": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a user agent for a specific website by tapping the '+' icon on the toolbar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Webサイト専用のユーザーエージェントを追加するには、ツールバーの「＋」アイコンをタッチしてください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um agente de usuário para um site específico clicando no botão '+'. "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击添加按钮开始添加每个网站的设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊新增按鈕開始新增每個網站的設定。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie einen User-Agent für eine bestimmte Website hinzu, indem Sie auf das „+“-Symbol in der Symbolleiste tippen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añada un agente de usuario para un sitio web específico tocando el icono ‘+’ en la barra de herramientas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un agent utilisateur pour un site web spécifique en touchant l’icône « + » dans la barre d’outils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un user agent per un sito web specifico toccando l’icona ‘+’ nella barra degli strumenti."
          }
        }
      }
    },
