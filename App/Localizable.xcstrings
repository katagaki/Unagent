            "state": "translated",
            "value": "The backup file could not be read."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer el archivo de copia de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier de sauvegarde n’a pas pu être lu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile leggere il file di backup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
