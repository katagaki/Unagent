          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível ler o arquivo de backup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取备份文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法讀取備份檔案。"
          }
        }
      }
    },
    "Backup.Error.iCloudUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud ist nicht verfügbar. Stellen Sie sicher, dass Sie bei iCloud angemeldet sind und iCloud Drive aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud is not available. Make sure you are signed in to iCloud and that iCloud Drive is enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud no está disponible. Asegúrese de haber iniciado sesión en iCloud y de que iCloud Drive esté activado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud n’est pas disponible. Assurez-vous d’être connecté à iCloud et qu’iCloud Drive est activé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud non è disponibile. Assicurati di aver eseguito l’accesso a iCloud e che iCloud Drive sia attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudが利用できません。iCloudにサインインし、iCloud Driveが有効になっていることを確認してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O iCloud não está disponível. Verifique se você fez login no iCloud e se o iCloud Drive está ativado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud不可用。请确保您已登录iCloud并已启用iCloud云盘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud無法使用。請確保您已登入iCloud並已啟用iCloud雲碟。"
          }
        }
      }
    },
