    "Presets.Custom.EmptyText": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie eine eigene Voreinstellung hinzu, indem Sie auf die „+“-Taste tippen."
          }
        },
        "en": {
          "stringUnit": {
