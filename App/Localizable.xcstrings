    },
    "SetUp.Step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In Safari settings, enable all website access for Unagent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Safariの設定で、Unagentのすべてのウェブサイトへのアクセスを許可します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nas configurações do Safari, ative o acesso a todos os sites para o Unagent."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Safari 设置中，为 Unagent 启用所有网站访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Safari 設定中，為 Unagent 啟用所有網站存取權限。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie in den Safari-Einstellungen den Zugriff auf alle Websites für Unagent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En los ajustes de Safari, active el acceso a todos los sitios web para Unagent."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans les réglages de Safari, activez l’accès à tous les sites web pour Unagent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nelle impostazioni di Safari, abilita l’accesso a tutti i siti web per Unagent."
          }
        }
      }
    },
    "SetUp.Step2.Title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give Unagent Access"
