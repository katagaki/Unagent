    "Restore.ChooseStrategy": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie möchten Sie wiederherstellen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How would you like to restore?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo desea restaurar?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment souhaitez-vous restaurer ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Come vuoi ripristinare?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのように復元しますか？"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Como você gostaria de restaurar?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您想如何恢复？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您想如何還原？"
          }
        }
      }
    },
    "Restore.ChooseStrategy.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Zusammenführen bleiben Ihre vorhandenen Daten erhalten und Duplikate werden überschrieben. Beim Überschreiben werden alle Ihre aktuellen Daten ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Merge keeps your existing data and overwrites any duplicates. Overwrite replaces all of your current data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Combinar conserva sus datos existentes y sobrescribe los duplicados. Sobrescribir reemplaza todos sus datos actuales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusionner conserve vos données existantes et remplace les doublons. Remplacer écrase toutes vos données actuelles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Unisci mantiene i tuoi dati esistenti e sovrascrive eventuali duplicati. Sovrascrivi sostituisce tutti i tuoi dati attuali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「結合」は既存のデータを保持し、重複するデータを上書きします。「上書き」は現在のすべてのデータを置き換えます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesclar mantém seus dados existentes e sobrescreve duplicatas. Substituir troca todos os seus dados atuais."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“合并”会保留您现有的数据并覆盖重复项。“覆盖”会替换您当前的所有数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「合併」會保留您現有的資料並覆蓋重複項目。「覆蓋」會取代您目前的所有資料。"
          }
        }
      }
    },
