    "Error.DuplicateDomain.Message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A setting for this domain already exists. Please edit the existing setting instead."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このドメインの設定は既に存在します。代わりに既存の設定を編集してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma configuração para este domínio já existe. Edite a configuração existente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此域名的设置已存在。请编辑现有设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此網域的設定已存在。請編輯現有設定。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Einstellung für diese Domain existiert bereits. Bitte bearbeiten Sie stattdessen die vorhandene Einstellung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe una configuración para este dominio. Edite la configuración existente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un réglage pour ce domaine existe déjà. Veuillez modifier le réglage existant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste già un’impostazione per questo dominio. Modifica l’impostazione esistente."
          }
        }
      }
    },
