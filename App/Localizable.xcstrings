{
  "sourceLanguage": "en",
  "strings": {
    "About.UserAgent": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser User-Agent wird an Websites übermittelt. Websites können diesen möglicherweise nicht als Kennung für Ihren Browser verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This user agent will be communicated to websites. Websites may not opt to use this as an identifier for your browser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este agente de usuario se comunicará a los sitios web. Los sitios web pueden optar por no usarlo como identificador de su navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet agent utilisateur sera communiqué aux sites web. Les sites web peuvent choisir de ne pas l’utiliser comme identifiant de votre navigateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo user agent verrà comunicato ai siti web. I siti web potrebbero non utilizzarlo come identificatore del browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このユーザーエージェントはウェブサイトに送信されます。ウェブサイトはこれをブラウザの識別子として使用しない場合があります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este agente de usuário será comunicado aos sites. Os sites podem optar por não usar isso como identificador do seu navegador."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此用户代理将传达给网站。网站可能不会选择将其用作浏览器的标识符。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此使用者代理將傳達給網站。網站可能不會選擇將其用作瀏覽器的識別碼。"
          }
        }
      }
    },
    "About.UserAgent.Tokens": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie %OS_MAJOR%, %OS_MINOR% und %OS_PATCH% als Platzhalter für die aktuelle Betriebssystemversion des Geräts."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use %OS_MAJOR%, %OS_MINOR%, and %OS_PATCH% as placeholders for the device’s current OS version components."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use %OS_MAJOR%, %OS_MINOR% y %OS_PATCH% como marcadores para los componentes de la versión actual del sistema operativo del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez %OS_MAJOR%, %OS_MINOR% et %OS_PATCH% comme marqueurs pour les composants de la version actuelle du système d’exploitation de l’appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa %OS_MAJOR%, %OS_MINOR% e %OS_PATCH% come segnaposto per i componenti della versione attuale del sistema operativo del dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%OS_MAJOR%、%OS_MINOR%、%OS_PATCH% をデバイスの現在のOSバージョンのプレースホルダーとして使用できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use %OS_MAJOR%, %OS_MINOR% e %OS_PATCH% como marcadores para os componentes da versão atual do sistema operacional do dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 %OS_MAJOR%、%OS_MINOR% 和 %OS_PATCH% 作为设备当前操作系统版本组件的占位符。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 %OS_MAJOR%、%OS_MINOR% 和 %OS_PATCH% 作為裝置目前作業系統版本組件的佔位符。"
          }
        }
      }
    },
    "About.Viewport": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Festlegen des Viewports ändert die Größe einer Website, die in Ihrem Browser angezeigt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Setting the viewport will change the size of a website displayed in your browser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurar la ventana gráfica cambiará el tamaño de un sitio web mostrado en su navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le réglage de la fenêtre d’affichage modifiera la taille d’un site web affiché dans votre navigateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’impostazione del viewport cambierà la dimensione di un sito web visualizzato nel browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビューポートを設定すると、ブラウザに表示されるウェブサイトのサイズが変更されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Definir a janela de visualização alterará o tamanho de um site exibido no seu navegador."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置视口将改变浏览器中显示的网站大小。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定視口將改變瀏覽器中顯示的網站大小。"
          }
        }
      }
    },
