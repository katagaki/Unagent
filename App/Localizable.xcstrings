            "value": "Die ausgewählte Anzeigegröße wird nur auf Seiten der angegebenen Domain angewendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected display size will only be applied to pages in the domain specified."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tamaño de visualización seleccionado solo se aplicará a las páginas del dominio especificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La taille d’affichage sélectionnée ne sera appliquée qu’aux pages du domaine spécifié."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La dimensione di visualizzazione selezionata verrà applicata solo alle pagine del dominio specificato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択された表示サイズは指定したドメインのページのみ適用されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tamanho de exibição selecionado será aplicado apenas às páginas do domínio especificado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选显示尺寸仅应用于指定域中的页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所選顯示尺寸僅套用於指定網域中的頁面。"
          }
        }
      }
