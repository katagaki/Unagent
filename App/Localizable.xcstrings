          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法建立備份。"
          }
        }
      }
    },
    "Backup.Error.ReadFailed": {
      "extractionState": "manual",
      "localizations": {
