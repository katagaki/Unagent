          }
        }
      }
    },
    "GlobalSettings.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Einstellungen werden auf alle Websites angewendet, es sei denn, eine seitenspezifische Einstellung ist für eine bestimmte Domain konfiguriert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These settings will be applied to all websites, except when a per-site setting is configured for a specific domain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estas configuraciones se aplicarán a todos los sitios web, excepto cuando se configure una configuración por sitio para un dominio específico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces réglages seront appliqués à tous les sites web, sauf lorsqu’un réglage par site est configuré pour un domaine spécifique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Queste impostazioni verranno applicate a tutti i siti web, tranne quando è configurata un’impostazione per sito per un dominio specifico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらの設定は、特定のドメインにサイト別設定が構成されている場合を除き、すべてのウェブサイトに適用されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essas configurações serão aplicadas a todos os sites, exceto quando uma configuração por site for definida para um domínio específico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些设置将应用于所有网站，除非为特定域配置了每个网站的设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這些設定將套用於所有網站，除非為特定網域設定了每個網站的設定。"
          }
        }
      }
    },
