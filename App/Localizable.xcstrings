    "SetUp.Step1.iOS18+": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Öffnen Sie die Einstellungen-App.\n2. Scrollen Sie nach unten und tippen Sie auf „Apps“.\n3. Suchen und tippen Sie auf „Safari“.\n4. Tippen Sie auf „Erweiterungen“.\n5. Tippen Sie auf „Unagent“.\n6. Aktivieren Sie Unagent für die Profile, in denen Sie Unagent verwenden möchten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Open the Settings app.\n2. Scroll down and tap 'Apps'.\n3. Find and tap 'Safari'.\n4. Tap 'Extensions'.\n5. Tap 'Unagent'.\n6. Toggle Unagent on for the profiles you wish to use Unagent in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Abra la app Ajustes.\n2. Desplácese hacia abajo y pulse ‘Apps’.\n3. Busque y pulse ‘Safari’.\n4. Pulse ‘Extensiones’.\n5. Pulse ‘Unagent’.\n6. Active Unagent para los perfiles en los que desee usarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Ouvrez l’app Réglages.\n2. Faites défiler vers le bas et touchez « Apps ».\n3. Recherchez et touchez « Safari ».\n4. Touchez « Extensions ».\n5. Touchez « Unagent ».\n6. Activez Unagent pour les profils dans lesquels vous souhaitez l’utiliser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Apri l’app Impostazioni.\n2. Scorri verso il basso e tocca \"App\".\n3. Trova e tocca \"Safari\".\n4. Tocca \"Estensioni\".\n5. Tocca \"Unagent\".\n6. Attiva Unagent per i profili in cui desideri utilizzarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "① 「設定」アプリを開きます。\n② 下にスクロールし、「アプリ」をタッチします。\n③ 「Safari」を探してタッチします。\n④ 「拡張機能」をタッチします。\n⑤ 「Unagent」をタッチします。\n⑥ Unagentを有効化するプロフィールをオンにします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Abra os Ajustes.\r\n2. Role para baixo e clique em 'Apps'.\n3. Role para baixo e clique em 'Safari'.\r\n4. Clique em 'Extensões'.\r\n5. Clique em 'Unagent'.\r\n6. Ative o Unagent para os perfis onde você deseja usar o Unagent."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 打开“设置”App。\n2. 向下滚动并轻点“App”。\n3. 找到并轻点“Safari”。\n4. 轻点“扩展”。\n5. 轻点“Unagent”。\n6. 为您希望使用 Unagent 的描述文件开启 Unagent。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 開啟「設定」App。\n2. 向下捲動並點一下「App」。\n3. 找到並點一下「Safari」。\n4. 點一下「擴充功能」。\n5. 點一下「Unagent」。\n6. 為您想要使用 Unagent 的設定檔開啟 Unagent。"
          }
        }
      }
    },
    "SetUp.Step2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie in den Safari-Einstellungen den Zugriff auf alle Websites für Unagent."
