    "More.AutoRefresh.Description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, wird beim nächsten Besuch einer Webseite in Safari nach einer User-Agent-Änderung die Seite automatisch neu geladen. Wenn deaktiviert, wird der User-Agent erst ab der 2. besuchten Webseite aktualisiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When turned on, any user agent change will cause a refresh the next time you visit a webpage in Safari. When turned off, user agents will only be updated on the 2nd webpage you visit or load."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, cualquier cambio de agente de usuario provocará una recarga la próxima vez que visites una página web en Safari. Cuando está desactivado, los agentes de usuario solo se actualizarán en la 2.ª página web que visites o cargues."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, tout changement d'agent utilisateur provoquera un rechargement lors de votre prochaine visite d'une page web dans Safari. Lorsqu'elle est désactivée, les agents utilisateurs ne seront mis à jour qu'à partir de la 2e page web visitée ou chargée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando attivo, qualsiasi modifica dello user agent causerà un ricaricamento alla prossima visita di una pagina web in Safari. Quando disattivo, gli user agent verranno aggiornati solo dalla 2ª pagina web visitata o caricata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、ユーザーエージェントを変更後Safariで次にWebページを訪問する際に一回再読み込みが発生します。オフの場合、変更後2つ目に訪問するWebページから反映されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, qualquer alteração de agente de usuário causará um recarregamento na próxima vez que você visitar uma página web no Safari. Quando desativado, os agentes de usuário só serão atualizados na 2ª página web que você visitar ou carregar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，任何用户代理更改都会在您下次访问Safari中的网页时自动刷新。关闭后，用户代理仅在您访问或加载的第2个网页时更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，任何使用者代理變更都會在您下次造訪Safari中的網頁時自動重新整理。關閉後，使用者代理僅在您造訪或載入的第2個網頁時更新。"
          }
        }
      }
    },
